class Solution:

    def winner(self, arr):
        freq = {}
        
        for name in arr:
            freq[name] = freq.get(name, 0) + 1
        
        max_votes = -1
        winner_name = ""
        
        for name in freq:
            if freq[name] > max_votes:
                max_votes = freq[name]
                winner_name = name
            elif freq[name] == max_votes:
                if name < winner_name:
                    winner_name = name
        
        return [winner_name, str(max_votes)]
