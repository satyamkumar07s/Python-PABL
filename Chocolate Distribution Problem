class Solution:
    def findMinDiff(self, arr, m):
        n = len(arr)
        if m == 0 or n == 0:
            return 0
        
        arr.sort()  
        min_diff = float('inf')
        
        
        for i in range(n - m + 1):
            min_diff = min(min_diff, arr[i + m - 1] - arr[i])
        
        return min_diff
